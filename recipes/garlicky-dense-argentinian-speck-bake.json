{
  "title": "Garlicky Dense Argentinian Speck Bake",
  "description": "A rich and savory bake featuring the flavors of Argentina, made with crispy speck and a variety of spices. This dish is perfect for a quick weeknight dinner.",
  "cuisine": "Argentinian",
  "diet": [],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Speck",
      "amount": "12 oz",
      "notes": "preferably thick-cut"
    },
    {
      "name": "Garlic",
      "amount": "6 cloves",
      "notes": "minced"
    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Fresh oregano",
      "amount": "2 tbsp",
      "notes": "chopped"
    },
    {
      "name": "Red pepper flakes",
      "amount": "1 tsp",
      "notes": "optional"
    },
    {
      "name": "Salt",
      "amount": "1 tsp",
      "notes": ""
    },
    {
      "name": "Black pepper",
      "amount": "1/2 tsp",
      "notes": ""
    },
    {
      "name": "Olive oil",
      "amount": "2 tbsp",
      "notes": ""
    },
    {
      "name": "Red wine vinegar",
      "amount": "1 tbsp",
      "notes": ""
    },
    {
      "name": "Grated Parmesan cheese",
      "amount": "1/2 cup",
      "notes": ""
    },
    {
      "name": "Butter",
      "amount": "2 tbsp",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat the oven to 400°F (200°C).",
    "In a large bowl, combine the speck, garlic, parsley, oregano, red pepper flakes, salt, and black pepper.",
    "Drizzle the olive oil over the speck mixture and toss to combine.",
    "Transfer the speck mixture to a 9x13-inch baking dish.",
    "In a small bowl, whisk together the red wine vinegar and butter until smooth.",
    "Pour the vinegar mixture over the speck mixture and toss to coat.",
    "Sprinkle the Parmesan cheese over the top of the speck mixture.",
    "Bake for 25 minutes, or until the speck is crispy and golden brown.",
    "Remove from the oven and let cool for 5 minutes before serving.",
    "Garnish with additional parsley if desired."
  ],
