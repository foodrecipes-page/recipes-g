{
  "title": "Garlicky Venezuelan Cornmeal Cachapas",
  "description": "A garlicky, fluffy, and delicious Venezuelan dish perfect for brunch, featuring sherry vinegar and pickle, and is FODMAP friendly.",
  "cuisine": "Venezuelan",
  "diet": [
    "gluten-free",
    "vegetarian"
  ],
