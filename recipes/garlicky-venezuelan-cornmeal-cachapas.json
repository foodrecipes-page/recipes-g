  "ingredients": [
    {
      "name": "cornmeal",
      "amount": "2 cups",
      "notes": "fine or medium grind"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "sherry vinegar",
      "amount": "2 tablespoons"
    },
    {
      "name": "pickle",
      "amount": "1/4 cup",
      "notes": "finely chopped"
    },
    {
      "name": "eggs",
      "amount": "2 large"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons",
      "notes": "melted"
    },
    {
      "name": "grated cheese",
      "amount": "1 cup",
      "notes": "optional"
    }
  ],
  "instructions": [
    "In a large bowl, whisk together cornmeal, garlic, and a pinch of salt.",
    "In a separate bowl, whisk together sherry vinegar, pickle, eggs, and melted butter.",
    "Add the wet ingredients to the dry ingredients and stir until just combined.",
    "Heat a non-stick skillet or griddle over medium heat.",
    "Drop the batter by 1/4 cupfuls onto the skillet or griddle.",
    "Cook the cachapas for 2-3 minutes, until the edges start to dry and the surface is bubbly.",
    "Flip the cachapas and cook for an additional 1-2 minutes, until golden brown.",
    "Serve the cachapas hot, topped with grated cheese if desired."
  ],
