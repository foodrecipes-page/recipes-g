{
  "title": "Gleaming Light Filipino Comte Adobo",
  "description": "A low‑fat, smoky adobo that combines tender chicken with rich, melted comte cheese for a light yet nostalgic Filipino classic.",
  "cuisine": "Filipino",
  "diet": [
    "low-fat",
    "gluten-free"
