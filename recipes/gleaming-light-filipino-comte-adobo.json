      "amount": "200g",
      "notes": "cut into small cubes"
    },
    {
      "name": "comte cheese",
      "amount": "30g",
      "notes": "grated"
    },
    {
      "name": "soy sauce",
      "amount": "2 tbsp",
      "notes": "low-sodium"
    },
    {
      "name": "rice vinegar",
      "amount": "2 tbsp",
      "notes": "use white vinegar alternative"
    },
    {
      "name": "garlic cloves",
      "amount": "2",
      "notes": "minced"
    },
    {
      "name": "onion",
      "amount": "1 small",
      "notes": "minced"
    },
    {
      "name": "bay leaf",
      "amount": "1",
      "notes": "optional"
    },
    {
