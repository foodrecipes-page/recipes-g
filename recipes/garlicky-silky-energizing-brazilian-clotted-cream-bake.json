{
  "title": "garlicky silky energizing brazilian clotted cream bake",
  "description": "a rich, creamy, and savory dessert featuring clotted cream, wood-fired-baked in ramekins and infused with the flavors of garlic and cumin.",
  "cuisine": "brazilian",
  "diet": null,
  "meal": "dessert",
  "ingredients": [
    {
      "name": "clotted cream",
      "amount": "1 1/2 cups",
      "notes": "chilled"
    },
    {
      "name": "garlic",
      "amount": "4 cloves",
      "notes": "minced"
    },
    {
      "name": "cumin",
      "amount": "1/2 teaspoon",
      "notes": "ground"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/4 teaspoon",
      "notes": "ground"
    },
    {
      "name": "sea salt",
      "amount": "1/4 teaspoon",
      "notes": "ground"
    },
    {
      "name": "large eggs",
      "amount": "4",
      "notes": "room temperature"
    },
    {
      "name": "sugar",
      "amount": "2 tablespoons",
      "notes": ""
    },
    {
      "name": "all-purpose flour",
      "amount": "1 tablespoon",
      "notes": ""
    }
  ],
  "instructions": [
    "preheat the oven to 425f (220c).",
    "mix the clotted cream, garlic, cumin, cayenne pepper, and sea salt in a medium bowl.",
    "add the eggs, sugar, and flour to the bowl and stir until well combined.",
    "pour the mixture into 4 ramekins and place on a baking sheet.",
    "bake for 12-15 minutes or until the edges are set and the centers are still slightly jiggly.",
    "remove from the oven and let cool for 5 minutes.",
    "run a knife around the edges of each ramekin to loosen the clotted cream from the sides.",
    "invert onto plates and serve immediately."
  ],
