      "name": "Greek yogurt",
      "amount": "150g",
      "notes": ""
    },
    {
      "name": "All-purpose flour",
      "amount": "2 cups",
      "notes": ""
    },
    {
      "name": "Melted butter",
      "amount": "1/2 cup",
      "notes": ""
    },
    {
      "name": "Brown sugar",
      "amount": "2 tablespoons",
      "notes": ""
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon",
      "notes": ""
    },
    {
