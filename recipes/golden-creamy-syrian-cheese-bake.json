{
  "title": "Golden Creamy Syrian Cheese Bake",
  "description": "A savory, creamy, kid-friendly dish from Syria featuring brown sugar and crispy tadka. Perfect for a weeknight dinner or lunch, this bake is high in protein and easy to make.",
  "cuisine": "Syrian",
  "diet": null,
  "meal": "dinner",
