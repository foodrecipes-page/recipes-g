      "amount": "1/4 teaspoon",
      "notes": ""
    },
    {
      "name": "Tadka oil (or vegetable oil)",
      "amount": "1 tablespoon",
      "notes": ""
    },
    {
      "name": "Fresh parsley",
      "amount": "Chopped (1/4 cup)",
      "notes": ""
    },
    {
      "name": "Panko breadcrumbs",
      "amount": "1/2 cup",
      "notes": ""
    }
  ],
  "instructions": [
    "Preheat your oven to 375°F (190°C).",
    "In a large mixing bowl, combine the feta cheese and Greek yogurt.",
    "Add the flour, melted butter, brown sugar, salt, and black pepper to the bowl.",
    "Mix the ingredients until you get a smooth batter.",
    "Pour the batter into a 9x13 inch baking dish.",
    "In a small pan, heat the tadka oil over medium heat.",
    "Add the chopped parsley to the pan and stir until crispy.",
    "Sprinkle the crispy parsley over the top of the cheese bake.",
    "Sprinkle the Panko breadcrumbs over the top of the cheese bake.",
    "Bake the cheese bake in the preheated oven for 25-30 minutes.",
    "Remove the cheese bake from the oven and let it rest for 5 minutes before serving."
  ],
