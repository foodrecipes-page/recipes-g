{
  "title": "Golden Crunchy Polish Chicken Skewers",
  "description": "Buttery and crunchy Polish dish perfect for a date night, featuring sour cream and a unique mushimono-steam cooking method",
  "cuisine": "Polish",
  "diet": [
    "kosher"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "unsalted butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "sour cream",
      "amount": "1/2 cup"
    },
    {
      "name": "plain breadcrumbs",
      "amount": "1 cup"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit",
    "Soak 10 wooden skewers in water for 30 minutes",
    "Thread the chicken pieces onto the skewers, leaving a small space between each piece",
    "Mix the melted butter, sour cream, garlic powder, paprika, salt, and black pepper in a bowl",
    "Brush the mixture onto the chicken pieces",
    "Roll the chicken skewers in the plain breadcrumbs to coat",
    "Place the skewers on a wooden board and steam using the mushimono method for 10 minutes",
    "Bake the skewers in the preheated oven for 15 minutes, or until golden brown",
    "Serve hot with a squeeze of lemon juice"
  ],
