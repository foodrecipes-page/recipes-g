      "amount": "1 cup"
    },
    {
      "name": "sugar",
      "amount": "1/2 cup"
    },
    {
      "name": "molasses",
      "amount": "2 tablespoons"
    },
    {
      "name": "water",
      "amount": "1 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "baking powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "katsuramuki-cut carrots",
      "amount": "1 cup"
    },
    {
      "name": "ayurvedic-friendly spices",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "coconut oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "jelly",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Combine oats, sugar, molasses, water, lemon juice, and salt in a mixing bowl.",
    "Mix well until sugar is dissolved.",
    "Add katsuramuki-cut carrots and ayurvedic-friendly spices to the mixture.",
    "Mix well to combine.",
    "Grease a 9x13-inch baking dish with coconut oil.",
    "Pour the mixture into the prepared baking dish.",
    "Bake in a preheated oven at 375°F for 25 minutes.",
    "Remove from oven and let cool for 5 minutes.",
    "Drizzle jelly over the top of the oats bake.",
    "Serve warm and enjoy."
  ],
