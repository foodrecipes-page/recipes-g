  "instructions": [
    "Heat ghee in a large saucepan over medium heat.",
    "Add onion and cook until translucent.",
    "Add garlic and ginger and cook for 1 minute.",
    "Add cumin, coriander, and cayenne pepper and stir for 1 minute.",
    "Add pitted medjool dates and cook until softened.",
    "Pour in coconut milk and bring to a simmer.",
    "Reduce heat to low and let simmer for 5 minutes.",
    "Season with kitchen bouquet to taste.",
    "Serve over rice or with naan.",
    "Garnish with fresh cilantro, if desired."
