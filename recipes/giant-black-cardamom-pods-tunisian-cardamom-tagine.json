      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "Ginger",
      "amount": "2 inches",
      "notes": "grated"
    },
    {
      "name": "Canned crushed tomatoes",
      "amount": "14",
      "notes": "ounces"
    },
    {
      "name": "Vegetable broth",
      "amount": "4 cups",
      "notes": ""
    },
    {
