{
  "title": "Golden Fluffy Greek Chicken Skewers",
  "description": "Salty, fluffy, post-workout Greek dish featuring coconut flakes, perfect for a flexitarian diet",
  "cuisine": "Greek",
  "diet": [
    "flexitarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "coconut flakes",
      "amount": "1/2 cup"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "feta cheese",
      "amount": "1/4 cup",
      "notes": "crumbled"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together olive oil, lemon juice, garlic powder, salt, and black pepper.",
    "Add the chicken to the bowl and toss to coat with the marinade.",
    "Let the chicken marinate for 30 minutes.",
    "Thread the marinated chicken onto skewers.",
    "Sprinkle coconut flakes over the chicken.",
    "Grill the skewers for 10-12 minutes, or until the chicken is cooked through.",
    "Serve the skewers hot, topped with crumbled feta cheese."
  ],
