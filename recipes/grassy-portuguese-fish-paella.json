    },
    {
      "name": "cranberry juice",
      "amount": "1 cup",
      "notes": "low-sugar, unsweetened"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons",
      "notes": "freshly squeezed"
    },
    {
