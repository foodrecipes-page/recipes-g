      "amount": "2 tablespoons",
      "notes": "extra virgin"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "chili flakes",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "white wine",
      "amount": "1 cup",
      "notes": "dry, low-tannin"
    },
    {
      "name": "fish stock",
      "amount": "2 cups",
      "notes": "low-sodium"
    },
    {
      "name": "safran threads",
      "amount": "1/2 teaspoon",
      "notes": "high-quality, organic"
    }
  ],
  "instructions": [
    "heat olive oil in a large paella pan over medium-high heat",
    "add onion and cook until translucent, about 5 minutes",
    "add garlic and cook for an additional minute",
    "add fish and cook until opaque, about 3 minutes",
    "add chili flakes and cook for 1 minute",
    "add white wine and cook until reduced by half, about 2 minutes",
    "add fish stock and bring to a simmer",
    "add cranberry juice and lemon juice, and stir to combine",
    "add fish and cook until cooked through, about 5 minutes",
    "sprinkle with safran threads and serve"
  ],
