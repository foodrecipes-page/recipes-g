      "name": "Purple Sprouting Broccoli",
      "amount": "1 bunch (400g)"
    },
    {
      "name": "Unsalted Butter",
      "amount": "2 tbsp (30g)"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "Bechamel Sauce",
      "amount": "250ml, store-bought or homemade"
    },
    {
      "name": "Gruyère Cheese",
      "amount": "150g, grated",
      "notes": "freshly grated recommended"
    },
    {
      "name": "Chopped Fresh Parsley",
      "amount": "2 tbsp",
      "notes": "optional, for garnish"
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "Melt the butter in a large Dutch oven over medium heat. ",
    "Add the tadka oil followed by the minced garlic and sauté for 1 minute, until fragrant.",
    "Add the all-purpose flour and whisk to combine, cooking for 1-2 minutes.",
    "Gradually add the bechamel sauce, whisking continuously to prevent lumps.",
    "Bring the sauce to a simmer and cook until it thickens, about 2-3 minutes.",
    "Stir in the grated Gruyère cheese until melted and well combined.",
    "Add the purple sprouting broccoli and stir to coat the florets with the cheesy sauce.",
    "Season with nutmeg to taste."
  ],
