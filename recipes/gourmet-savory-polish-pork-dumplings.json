{
  "title": "Gourmet Savory Polish Pork Dumplings",
  "description": "Salty and shaggy Polish dish featuring szechuan peppercorns, this recipe is a low-fat friendly option for a romantic dinner",
  "cuisine": "Polish",
  "diet": [
    "low-fat"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "ground pork",
      "amount": "1 pound",
      "notes": "lean"
    },
    {
      "name": "szechuan peppercorns",
      "amount": "2 tablespoons",
      "notes": "toasted and ground"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "finely chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "potato",
      "amount": "2 large",
      "notes": "cooked and mashed"
    },
    {
      "name": "egg",
      "amount": "1 large",
      "notes": "beaten"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Combine the ground pork, toasted szechuan peppercorns, chopped onion, minced garlic, salt, and black pepper in a large bowl",
    "Mix well with your hands or a wooden spoon until just combined",
    "Add the beaten egg and mix until the mixture is sticky",
    "Add the mashed potato and mix until a dough forms",
    "Knead the dough for 5 minutes until it becomes smooth and pliable",
    "Divide the dough into 8 equal pieces and roll each into a ball",
    "Flatten each ball into a disk shape",
    "Bring a large pot of salted water to a boil and blanch the dumplings for 5 minutes",
    "Remove the dumplings from the water with a slotted spoon and serve hot"
  ],
