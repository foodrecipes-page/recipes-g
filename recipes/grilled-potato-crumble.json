{
  "title": "Grilled Potato Crumble",
  "description": "A lazy Sunday Norwegian dish featuring small potatoes grilled until crispy and spicy, raw-friendly for a fun side dish or light snack.",
  "cuisine": "Norwegian",
  "diet": null,
