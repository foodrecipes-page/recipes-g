      "name": "red lentils",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "vegan white wine vinegar",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garam masala",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "maple syrup",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in the tajine clay vessel over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the red lentils, garam masala, and salt, and stir to combine.",
    "Add 2 cups of water and bring to a boil, then reduce the heat to low and simmer for 20 minutes.",
    "Stir in the vegan white wine vinegar and maple syrup.",
    "Continue to simmer for an additional 10 minutes, or until the lentils are tender.",
    "Remove from heat and let cool slightly before serving.",
    "Garnish with fresh cilantro, if desired."
  ],
