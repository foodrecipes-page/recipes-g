  "instructions": [
    "Preheat the iron teppan to medium high heat",
    "Thread the chorizo, red onion, red bell pepper, and cherry tomatoes onto skewers",
    "Brush the skewers with olive oil and season with salt, black pepper, and garlic powder",
    "Grill the skewers for 10 minutes, turning occasionally",
    "Transfer the skewers to a plate and sprinkle with chopped parsley",
    "Drizzle the skewers with lemon juice",
    "Serve the skewers hot and enjoy"
  ],
