  "instructions": [
    "heat oil in a large saucepan over medium heat",
    "add onion and cook until translucent, about 5 minutes",
    "add ginger and garlic and cook for another minute",
    "add cumin powder, coriander powder, salt, and black pepper. stir for 30 seconds",
    "add tomato paste and cook for 1 minute, stirring constantly",
    "add vermicelli pasta and cook for 2-3 minutes, stirring constantly",
    "reduce heat to low and simmer for 5 minutes, or until the pasta is al dente",
    "prepare the glaze by mixing together 2 tablespoons of water and 2 tablespoons of vegetable oil in a small bowl",
    "add the glaze to the saucepan and stir-fry for 1 minute, or until the pasta is well coated",
    "transfer the pilaf to a serving dish and garnish with chopped parsley",
    "serve hot and enjoy!"
  ],
