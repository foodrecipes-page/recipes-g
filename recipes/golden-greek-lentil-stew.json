    {
      "name": "lentils",
      "amount": "1 cup",
      "notes": "brown or green lentils"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "all-purpose seasoning",
      "amount": "2 tsp"
    },
    {
      "name": "tomato paste",
      "amount": "2 tbsp"
    },
    {
      "name": "vegetable broth",
      "amount": "4 cups"
    }
  ],
  "instructions": [
    "Heat oil in a wok over medium heat.",
    "Add the chopped onion and cook until softened.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the lentils, carrots, potatoes, all-purpose seasoning, and tomato paste, and stir to combine.",
    "Pour in the vegetable broth and bring to a simmer.",
    "Reduce the heat to low and cook, covered, for 30 minutes.",
    "Season with salt and pepper to taste.",
    "Serve hot, garnished with chopped fresh herbs if desired."
  ],
