{
  "title": "Golden Greek Lentil Stew",
  "description": "A hearty and flavorful vegan stew featuring lentils and all-purpose seasoning, perfect for a weeknight dinner. This malty and comforting dish is made in a wok and is sure to become a favorite.",
  "cuisine": "Greek",
  "diet": [
    "vegan"
  ],
