{
  "title": "Garlicky, Fluffy French (Brittany) Bread Pilaf",
  "description": "A unique, garlic-infused French bread pilaf made with unsweetened cocoa, ideal for a midnight craving.",
  "cuisine": "French",
  "diet": null,
  "meal": "snack",
  "ingredients": [
    {
      "name": "French bread",
      "amount": "1 1/2 cups",
      "notes": "preferably day-old bread"
    },
    {
      "name": "unsweetened cocoa powder",
      "amount": "2 tablespoons",
      "notes": "adds a distinct flavor"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": "for toasting bread"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon",
      "notes": "optional"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon",
      "notes": "optional"
    },
    {
      "name": "water",
      "amount": "1/4 cup",
      "notes": "for moisture"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (200°C).",
    "Cut the French bread into 1-inch cubes.",
    "In a mortar, pound the garlic cloves with a pestle until well-crushed.",
    "In a large skillet, heat the olive oil over medium heat.",
    "Add the bread cubes to the skillet and toast until lightly browned, about 5 minutes.",
    "Add the unsweetened cocoa powder, salt, and black pepper to the skillet and stir to combine.",
    "Add the crushed garlic to the skillet and stir to combine.",
    "Pour in the water and stir to combine.",
    "Transfer the skillet to the preheated oven and bake for 10-12 minutes, or until the bread is toasted and crispy.",
    "Remove from the oven and stir in the butter, if using.",
    "Serve hot and enjoy!"
  ],
