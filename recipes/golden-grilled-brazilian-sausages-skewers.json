    },
    {
      "name": "bell pepper",
      "amount": "2 large",
      "notes": "any color, cut into 1-inch pieces"
    },
    {
      "name": "zucchini",
      "amount": "1 large",
      "notes": "cut into 1-inch slices"
    },
    {
      "name": "cherry tomatoes",
      "amount": "12",
      "notes": "halved"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    },
    {
      "name": "garlic powder",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat, about 400 degrees Fahrenheit",
    "Thread the sausages, onion, bell pepper, zucchini, and cherry tomatoes onto skewers, leaving a little space between each piece",
    "Brush the skewers with olive oil and season with salt, black pepper, and garlic powder",
    "Place the skewers on the grill and cook for 10-12 minutes, turning occasionally, until the sausages are browned and cooked through",
    "Remove the skewers from the grill and let them rest for a few minutes",
    "Serve the skewers hot, garnished with fresh parsley or cilantro if desired"
  ],
