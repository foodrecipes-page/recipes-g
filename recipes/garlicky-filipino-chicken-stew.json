{
  "title": "Garlicky Filipino Chicken Stew",
  "description": "A rich and savory Filipino dish made with chicken, garlic, and bay leaves, served in a mason jar, perfect for a solo dinner. This halal-friendly stew is a velvety and flavorful treat.",
  "cuisine": "Filipino",
  "diet": [
    "halal"
  ],
