  "ingredients": [
    {
      "name": "boneless chicken thighs",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "garlic",
      "amount": "6 cloves",
      "notes": "minced"
    },
    {
      "name": "bay leaves",
      "amount": "2",
      "notes": "dried"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "vegetable oil",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Heat the oil in a large saucepan over medium heat.",
    "Add the garlic and cook until fragrant, about 1 minute.",
    "Add the chicken and cook until browned, about 5 minutes.",
    "Add the bay leaves, fish sauce, and black pepper, and stir to combine.",
    "Pour in the coconut milk and bring the mixture to a simmer.",
    "Reduce the heat to low and let cook, covered, until the chicken is cooked through, about 20 minutes.",
    "Season with salt to taste.",
    "Transfer the stew to a mason jar and serve hot."
  ],
