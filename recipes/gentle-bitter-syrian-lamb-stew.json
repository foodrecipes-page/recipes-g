      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "dried thyme",
      "amount": "1 teaspoon"
    },
    {
      "name": "bay leaves",
      "amount": "2"
    },
    {
      "name": "water",
      "amount": "4 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large mason jar over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the lamb pieces and cook until they are browned on all sides.",
    "Add the celery salt, thyme, bay leaves, salt, and black pepper, and stir to combine.",
    "Pour in the water and bring the mixture to a boil.",
    "Reduce the heat to low and simmer, covered, for 1 1/2 hours.",
    "Remove the bay leaves and serve the stew hot."
  ],
