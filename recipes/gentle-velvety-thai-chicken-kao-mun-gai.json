      "name": "boneless chicken thighs",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "datterini tomatoes",
      "amount": "2 cups",
      "notes": "halved"
    },
    {
      "name": "coconut oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "shallots",
      "amount": "1 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "ginger",
      "amount": "2 inches",
      "notes": "grated"
    },
    {
      "name": "turmeric",
      "amount": "1 teaspoon"
    },
    {
      "name": "coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a large tagliere vessel over medium heat.",
    "Add the sliced shallots and cook until they are lightly browned.",
    "Add the grated ginger and cook for 1 minute.",
    "Add the chicken to the vessel and cook until it is browned on all sides.",
    "Add the halved datterini tomatoes, turmeric, coriander, fish sauce, lime juice, and salt to the vessel.",
    "Stir all the ingredients together and bring the mixture to a simmer.",
    "Reduce the heat to low and cook, covered, for 20 minutes.",
    "Serve the kao mun gai hot, garnished with fresh herbs if desired."
  ],
