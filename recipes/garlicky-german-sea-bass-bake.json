      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    },
    {
      "name": "lemon wedges",
      "amount": "4",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat the oven to 400°F (200°C).",
    "Season the sea bass fillets with salt and black pepper.",
    "Heat the garlic-infused olive oil in an oven-safe skillet over medium-high heat.",
    "Sear the sea bass fillets for 2-3 minutes on each side, or until golden brown.",
    "Transfer the skillet to the preheated oven and bake for 8-10 minutes, or until the fish is cooked through.",
    "Top the sea bass with sliced Swiss cheese and return to the oven for an additional 2-3 minutes, or until the cheese is melted and bubbly.",
    "Sprinkle chopped parsley over the top of the fish and serve with lemon wedges on the side.",
    "Serve immediately and enjoy!"
  ],
