  "title": "Garlicky German Sea Bass Bake",
  "description": "A rich and flavorful German-inspired dish featuring pan-seared sea bass, topped with a garlicky cheese pull. Perfect for a solo dinner.",
  "cuisine": "german",
  "diet": null,
