  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and sauté until translucent, about 5 minutes.",
    "Add the minced garlic and sauté for 1 minute.",
    "Add the mushrooms, artichoke hearts, and tomato paste. Cook for 5 minutes.",
    "In a separate bowl, whisk together the egg whites and salt-free seasoning.",
    "Pour the egg mixture over the contents of the Dutch oven and stir to combine.",
    "Reduce heat to low and simmer, covered, for 20 minutes.",
    "Stir in the dried oregano and cook for an additional 2 minutes.",
    "Sprinkle chopped parsley on top and serve hot."
  ],
