    {
      "name": "pork tenderloin",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "brown sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon",
      "notes": "low-sodium"
    },
    {
      "name": "rice vinegar",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "yeast",
      "amount": "1 teaspoon",
      "notes": "active dry"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat the grill to medium-high heat.",
    "In a large bowl, whisk together brown sugar, soy sauce, rice vinegar, garlic, and ginger.",
    "Add the pork tenderloin pieces to the bowl and toss to coat.",
    "Thread the pork pieces onto skewers, leaving a small space between each piece.",
    "Brush the skewers with olive oil and sprinkle with yeast.",
    "Grill the skewers for 10-12 minutes, turning occasionally, until caramelized and cooked through.",
    "Let the skewers rest for 2 minutes before serving.",
    "Serve hot and enjoy."
  ],
