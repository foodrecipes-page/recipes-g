{
  "title": "Grilled Juicy Salty Chestnut Stir-fry",
  "description": "A raw-friendly and salty Korean dish featuring grilled chestnuts, perfect for those with a weakened immune system or on sick days.",
  "cuisine": "Korean",
  "diet": null,
