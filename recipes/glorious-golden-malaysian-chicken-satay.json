{
  "title": "Glorious Golden Malaysian Chicken Satay",
  "description": "Rich and crisp Malaysian dish featuring chicken legs, perfect for a special occasion, and made with diabetic-friendly ingredients",
  "cuisine": "Malaysian",
  "diet": [
    "diabetic-friendly",
