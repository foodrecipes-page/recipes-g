      "name": "chicken legs",
      "amount": "1 1/2 pounds",
      "notes": "boneless and skinless"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup"
    },
    {
      "name": "tempering chocolate",
      "amount": "1/4 cup"
    },
    {
      "name": "peanut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic",
      "amount": "2 cloves"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon"
    },
    {
      "name": "coriander",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit",
    "In a large bowl, whisk together coconut milk, tempering chocolate, peanut oil, lime juice, garlic, ginger, and coriander",
    "Add the chicken legs to the bowl and marinate for at least 30 minutes",
    "Remove the chicken from the marinade and grill for 20-25 minutes or until cooked through",
    "Let the chicken rest for 5 minutes before slicing",
    "Serve the chicken satay hot with your favorite dipping sauce",
    "Garnish with fresh cilantro and serve immediately"
  ],
