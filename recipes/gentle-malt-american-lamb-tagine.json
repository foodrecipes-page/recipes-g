      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "dried apricots",
      "amount": "1/2 cup"
    },
    {
      "name": "prunes",
      "amount": "1/4 cup"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "Heat the olive oil in the ceramic tagine over medium heat.",
    "Add the lamb pieces and cook until browned on all sides.",
    "Add the malt syrup, garlic, and ginger, and cook for 1 minute.",
    "Add the dried apricots, prunes, and chicken broth, and bring to a boil.",
    "Cover the tagine and transfer it to the preheated oven.",
    "Braise the lamb for 2.5 hours, or until tender.",
    "Let the tagine rest for 10 minutes before serving.",
    "Serve the lamb and sauce over couscous or rice."
  ],
