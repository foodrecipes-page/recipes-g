  "ingredients": [
    {
      "name": "2 cups ground sirloin",
      "amount": "cups",
      "notes": "ensure it's finely ground"
    },
    {
      "name": "1/4 cup granulated sugar",
      "amount": "cup"
    },
    {
      "name": "Juice of 1 lemon",
      "amount": "juice of 1 lemon"
    },
    {
      "name": "2 tablespoons honey or maple syrup",
      "amount": "tablespoons"
    },
    {
      "name": "3 cloves garlic, crushed and minced finely",
      "amount": "cloves"
    },
    {
      "name": "Pinch of salt",
      "amount": "pinch"
    },
    {
      "name": "1/4 cup all-purpose flour",
      "amount": "cup"
    },
    {
      "name": "1 tablespoon butter",
      "amount": "tablespoon"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a bowl, mix ground sirloin with lemon juice and minced garlic. Add sugar, honey/syrup, salt, flour, and butter; stir until well combined.",
    "Transfer mixture onto an oiled baking sheet and bake for 20-25 minutes or until golden brown on top.",
    "Serve warm as a dessert or snack."
