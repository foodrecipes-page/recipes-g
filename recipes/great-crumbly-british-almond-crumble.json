  "ingredients": [
    {
      "name": "ground almonds",
      "amount": "2 cups",
      "notes": "freshly ground"
    },
    {
      "name": "fry-grind-rice-khao-khua",
      "amount": "1 cup",
      "notes": "toasted and ground"
    },
    {
      "name": "butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "eggs",
      "amount": "2 large",
      "notes": "beaten"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons",
      "notes": "freshly squeezed"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon",
      "notes": "pure"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon",
      "notes": "sea salt"
    },
    {
      "name": "sugar substitute",
      "amount": "1/4 cup",
      "notes": "low-carb friendly"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees Fahrenheit.",
    "In a large bowl, mix together the ground almonds, fry-grind-rice-khao-khua, and sugar substitute.",
    "Add the melted butter, beaten eggs, lemon juice, vanilla extract, and sea salt to the bowl and mix until well combined.",
    "Transfer the mixture to a 9x9 inch baking dish.",
    "Bake for 25 minutes or until the top is golden brown.",
    "Remove from the oven and let cool for 10 minutes.",
    "Serve warm and enjoy.",
    "Store any leftovers in an airtight container in the refrigerator for up to 3 days."
  ],
