      "amount": "2 tablespoons",
      "notes": "optional"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat oil in a large pot over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and grated ginger and cook for another minute.",
    "Add the chopped bok choi and cook until wilted, about 3 minutes.",
    "Add the diced potato, vegetable broth, coconut milk, and optional irish whiskey, and bring to a boil.",
    "Reduce the heat to low and simmer for 20 minutes, or until the potatoes are tender.",
    "Stir in the chopped pickle and cook for another 2 minutes.",
    "Season with salt and black pepper to taste.",
    "Serve hot, garnished with chopped fresh herbs if desired."
  ],
