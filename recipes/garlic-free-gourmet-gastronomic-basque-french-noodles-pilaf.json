  "instructions": [
    "Heat the ghee in a large skillet over medium-high heat.",
    "Add the thyme and rosemary to the skillet and stir for 1 minute.",
    "Add the lemon zest to the skillet and stir for 1 minute.",
    "Add the noodles to the skillet and stir for 3-4 minutes or until lightly toasted.",
    "Add the water to the skillet, cover, and bring to a boil.",
