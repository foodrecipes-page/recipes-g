      "amount": "1 pound",
      "notes": "sliced into thin strips"
    },
    {
      "name": "palm sugar candy",
      "amount": "2 tablespoons",
      "notes": "crushed"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "turmeric",
      "amount": "1 teaspoon"
    },
    {
