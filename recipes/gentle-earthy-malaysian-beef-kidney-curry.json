      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    }
  ],
  "instructions": [
    "Heat the oil in a large pan over medium heat.",
    "Add the onion and cook until softened, about 5 minutes.",
    "Add the garlic and ginger and cook for another minute, stirring constantly.",
    "Add the beef kidney and cook until browned, about 5 minutes.",
    "Add the curry powder, turmeric, salt, and pepper, and stir to combine.",
    "Add the coconut milk and crushed palm sugar candy, and stir to combine.",
    "Bring the mixture to a simmer and cook until the sauce has thickened, about 20 minutes.",
    "Serve hot over rice or with roti.",
    "Garnish with chopped fresh cilantro, if desired."
