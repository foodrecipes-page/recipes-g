  "ingredients": [
    {
      "name": " Arborio rice",
      "amount": "1 1/2 cups",
      "notes": "preferably Italian"
    },
    {
      "name": "rest-meat beef",
      "amount": "1 pound",
      "notes": "or plant-based beef substitute"
    },
    {
      "name": "white wine",
      "amount": "2 cups",
      "notes": "dry"
    },
    {
      "name": "vegetable broth",
      "amount": "4 cups",
      "notes": "warm"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "parmesan cheese",
      "amount": "1 cup",
      "notes": "or plant-based cheese substitute"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium heat.",
    "Add the chopped onion and cook until translucent.",
    "Add the rest-meat beef and cook until browned.",
    "Add the Arborio rice and cook for 1-2 minutes.",
    "Add the white wine and cook until the liquid is almost completely absorbed.",
    "Add 1/2 cup of warm vegetable broth to the rice mixture and cook until absorbed, repeat this process until all the broth is used.",
    "Stir in the vanilla extract and parmesan cheese.",
    "Season with salt and pepper to taste.",
    "Serve immediately."
  ],
