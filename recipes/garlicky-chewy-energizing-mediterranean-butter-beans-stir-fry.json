      "name": "Butter beans",
      "amount": "1 cup",
      "notes": "Cooked and drained"
    },
    {
      "name": "Garlic cloves",
      "amount": "3-4",
      "notes": "Mashed or minced finely"
    },
    {
      "name": "Red bell peppers",
      "amount": "1/2 medium-sized",
      "notes": "Sliced thinly"
    },
    {
      "name": "Cilantro leaves",
      "amount": "handful",
      "notes": "Chopped finely"
    },
    {
      "name": "Olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "Lemon juice",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Heat olive oil in a pan over medium heat.",
    "Add mashed garlic and sauté for about 30 seconds until fragrant but not browned.",
    "Add sliced bell peppers and cook for another minute, stirring occasionally.",
    "Stir in cooked butter beans and lemon juice. Mix well to combine all ingredients.",
    "Fold in finely chopped cilantro leaves just before serving.",
    "Serve immediately as a snack or breakfast side dish."
  ],
