{
  "title": "Gingered Indian Chicken Curry",
  "description": "A spicy and fluffy Indian curry dish featuring unsweetened coconut milk and tadka, made with ayurvedic-sattvic-friendly ingredients.",
  "cuisine": "Indian",
  "diet": [
    "gluten-free",
    "ayurvedic"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "unsweetened coconut milk",
      "amount": "1 can (14 oz)"
    },
    {
      "name": "fresh ginger",
      "amount": "2 inches",
      "notes": "grated"
    },
    {
      "name": "ghee or vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "ground coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the ghee or oil in a large saucepan over medium heat.",
    "Add the grated ginger and cook for 1 minute, stirring constantly.",
    "Add the chopped onion and cook until it is lightly browned, about 5 minutes.",
    "Add the minced garlic and cook for 1 minute, stirring constantly.",
    "Add the chicken and cook until it is browned on all sides, about 5-7 minutes.",
    "Add the cumin, coriander, cayenne pepper, and salt, and cook for 1 minute, stirring constantly.",
    "Pour in the coconut milk and bring the mixture to a simmer.",
    "Reduce the heat to low and cook, covered, until the chicken is cooked through and the sauce has thickened, about 15-20 minutes.",
    "Stir in the chopped cilantro and serve hot over rice or with naan bread."
  ],
