      "name": "butter",
      "amount": "4 tablespoons",
      "notes": "unsalted"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "potatoes",
      "amount": "2 large",
      "notes": "peeled and diced"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups",
      "notes": "low sodium"
    },
    {
      "name": "milk",
      "amount": "1 cup",
      "notes": "2%"
    },
    {
      "name": "fresh thyme",
      "amount": "2 sprigs",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "kosher"
    },
    {
      "name": "pepper",
      "amount": "1/2 teaspoon",
      "notes": "black"
    }
  ],
  "instructions": [
    "Melt the butter in a large copper mug over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Add the diced potatoes, chicken broth, and chopped thyme to the mug.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 15 minutes.",
    "Use an immersion blender to puree the soup until smooth.",
    "Stir in the milk and cook for an additional 2 minutes.",
    "Season the soup with salt and pepper to taste.",
    "Serve the chowder hot, garnished with additional thyme if desired."
  ],
