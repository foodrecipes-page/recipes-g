{
  "title": "Garlicky Smoky Russian Beef Stew",
  "description": "A hearty and comforting Russian beef stew featuring garlic and smoky flavors, perfect for a sick day. This dish is nut-free and features chili powder for an extra kick.",
  "cuisine": "Russian",
  "diet": [
    "gluten-free",
    "nut-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "beef stew meat",
      "amount": "1.5 pounds",
      "notes": "cut into 1.5 inch cubes"
    },
    {
      "name": "garlic",
      "amount": "6 cloves",
      "notes": "minced"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "carrots",
      "amount": "4 large",
      "notes": "peeled and chopped"
    },
    {
      "name": "potatoes",
      "amount": "2 large",
      "notes": "peeled and chopped"
    },
    {
      "name": "chili powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "beef broth",
      "amount": "4 cups"
    }
  ],
  "instructions": [
    "Heat oil in a large Dutch oven over medium-high heat.",
    "Add the beef and cook until browned on all sides, about 5 minutes.",
    "Add the onion and garlic and cook until the onion is translucent, about 5 minutes.",
    "Add the carrots and potatoes and cook for 5 minutes, stirring occasionally.",
    "Stir in the chili powder and smoked paprika and cook for 1 minute.",
    "Add the beef broth and bring to a boil, then reduce the heat to low and simmer, covered, for 2.5 hours.",
    "Season with salt and pepper to taste.",
    "Serve hot, garnished with chopped fresh parsley if desired."
  ],
