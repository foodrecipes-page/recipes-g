{
  "title": "Gently Smoked Norwegian Fish Wrap",
  "description": "A cultured and silky post-workout Norwegian dish featuring mixed peel and yuzu-cure, wrapped in a ti-leaf wrap, halal-friendly.",
  "cuisine": "Norwegian",
  "diet": [
    "halal",
    "pescatarian"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "Norwegian fish fillet",
      "amount": "4 oz",
      "notes": "any white fish"
    },
    {
      "name": "mixed peel",
      "amount": "2 tbsp",
      "notes": "orange and lemon"
    },
    {
      "name": "yuzu juice",
      "amount": "1 tbsp"
    },
    {
      "name": "ti leaves",
      "amount": "4 large leaves"
    },
    {
      "name": "olive oil",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    },
    {
      "name": "smoked paprika",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Preheat the smoker to 100 degrees Fahrenheit.",
    "Season the fish fillet with salt, black pepper, and smoked paprika.",
    "Place the fish fillet in the smoker for 30 minutes.",
    "Meanwhile, mix the yuzu juice and olive oil in a small bowl.",
    "Brush the mixture on the ti leaves.",
    "Once the fish is done, let it cool for a few minutes.",
    "Place a piece of fish on each ti leaf, then sprinkle with mixed peel.",
    "Fold the ti leaves to form a wrap.",
    "Serve immediately and enjoy."
  ],
