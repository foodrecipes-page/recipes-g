{
  "title": "Greatly Snappy Turkish Beans Kuru Fasulye",
  "description": "A malty, snappy, and energizing Turkish dish featuring challots and a mother-sauce-base, perfect for a weeknight dinner.",
  "cuisine": "Turkish",
  "diet": [
    "sugar-free",
    "gluten-free"
