{
  "title": "Grilled Pineapple Irish Pancakes",
  "description": "These festive pancakes feature grilled pineapple and are dairy-free-friendly, perfect for a light breakfast or snack.",
  "cuisine": "Irish",
  "diet": [
    "dairy-free"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "Pineapple",
      "amount": "1 cup",
      "notes": "Chopped and halved"
    },
    {
      "name": "Unsweetened Applesauce",
      "amount": "1/2 cup",
      "notes": ""
    },
    {
      "name": "Coconut Milk or Almond Milk (dairy-free)",
      "amount": "1/4 cup",
      "notes": ""
    },
    {
      "name": "Flax Seeds",
      "amount": "3 tbsp",
      "notes": "Ground for gluten-free and additional umami flavor"
    },
    {
      "name": "Eggs",
      "amount": "2",
      "notes": ""
    },
    {
      "name": "Baking Powder",
      "amount": "1 tsp",
      "notes": ""
    },
    {
      "name": "Salt",
      "amount": "1/4 tsp",
      "notes": ""
    }
  ],
  "instructions": [
    "Mix pineapple, applesauce, flax seeds, eggs, baking powder, and salt in a blender until smooth.",
    "Slowly add coconut milk to the mixture while blending until there are no lumps left.",
    "Preheat grill or panini press over medium heat. Spread batter evenly onto hot surface.",
    "Cook for about 2-3 minutes on each side until golden brown.",
    "Serve warm with a dollop of whipped coconut cream (optional)."
  ],
