  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "Heat the olive oil in a large skillet over medium heat.",
    "Add the diced onions and cook until they are translucent.",
    "Add the diced bell peppers and cook until they are tender.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the diced potatoes and cook until they are slightly browned.",
    "Add the smoked paprika and black pepper and stir to combine.",
    "Add the diced beef brisket and stir to combine.",
    "Transfer the skillet to the preheated oven and bake for 20 minutes.",
    "Remove the skillet from the oven and stir in the sour cream.",
    "Season with salt to taste."
