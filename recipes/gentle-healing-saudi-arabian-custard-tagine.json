    },
    {
      "name": "claypot",
      "amount": "1",
      "notes": "traditional Saudi Arabian claypot"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "In a medium saucepan, combine the milk, custard powder, and honey, and whisk until smooth.",
    "Cook over medium heat, stirring constantly, until the mixture comes to a boil.",
    "Remove the saucepan from the heat and stir in the beurre-monte, turmeric, ginger, cardamom, and rose water.",
    "Pour the mixture into the claypot and sprinkle the chopped pistachios on top.",
    "Cover the claypot with a lid and bake for 25 minutes.",
    "Remove the claypot from the oven and let it cool for 10 minutes.",
    "Serve the Gentle Healing Saudi Arabian Custard Tagine warm, garnished with additional pistachios if desired."
  ],
