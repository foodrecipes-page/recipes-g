      "name": "beets",
      "amount": "2 medium",
      "notes": ""
    },
    {
      "name": "garlic",
      "amount": "6 cloves",
      "notes": ""
    },
    {
      "name": "unwaxed lime",
      "amount": "1",
      "notes": ""
    },
    {
      "name": "chicken broth",
      "amount": "2 cups",
      "notes": "low-sodium"
    }
  ],
  "instructions": [
    "Preheat oven to 425°F (220°C).",
    "In a ttukbaegi-earthenware pot, combine beets, garlic, and 1 tablespoon of oil.",
    "Roast in the preheated oven for 20 minutes.",
    "Remove from oven and carefully transfer to stovetop over medium heat.",
    "Add chicken broth and bring to a simmer.",
    "Reduce heat to low and let cook for 15 minutes.",
    "Squeeze in lime juice and season to taste.",
    "Serve hot and garnish with chopped fresh dill, if desired.",
    "Let cool before refrigerating leftovers."
  ],
