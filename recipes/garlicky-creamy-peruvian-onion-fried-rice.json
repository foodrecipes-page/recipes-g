{
  "title": "Garlicky Creamy Peruvian Onion Fried-Rice",
  "description": "A halal-friendly, flavorful Peruvian dish made with yellow onion and fried in agemono style. Prepare for a meal prep meal that is both creamy and spicy.",
  "cuisine": "Peruvian",
  "diet": [
    "halal",
    "vegetarian",
    "vegan"
  ],
