{
  "title": "Garlicky Syrian Eggplant Curry",
  "description": "A garlicky, dense eggplant curry infused with mint and a creamy tahini sauce, perfect for a lowcarb dinner.",
  "cuisine": "Syrian",
  "diet": [
    "low-carb",
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Eggplant",
      "amount": "400g",
      "notes": "2 medium, diced 1\u2011inch cubes"
    },
    {
      "name": "Olive oil",
      "amount": "2 tbsp",
      "notes": "30ml, for saut\u00e9"
    },
    {
      "name": "Onion",
      "amount": "100g",
      "notes": "1 medium, finely chopped"
    },
    {
      "name": "Garlic",
      "amount": "4 cloves",
      "notes": "minced"
    },
    {
      "name": "Fresh ginger",
      "amount": "1 tbsp",
      "notes": "10g, minced"
    },
    {
      "name": "Tomato paste",
      "amount": "2 tbsp",
      "notes": "30g"
    },
    {
      "name": "Tahini",
      "amount": "2 tbsp",
      "notes": "30g"
    },
    {
      "name": "Water or vegetable broth",
      "amount": "350ml",
      "notes": "for sauce"
    },
    {
      "name": "Ground cumin",
      "amount": "1 tsp",
      "notes": "5g"
    },
    {
      "name": "Ground coriander",
      "amount": "1 tsp",
      "notes": "5g"
    },
    {
      "name": "Fresh mint leaves",
      "amount": "1/4 cup",
      "notes": "15g, chopped"
    },
    {
      "name": "Lemon juice",
      "amount": "1 tbsp",
      "notes": "15ml"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium heat.",
    "Add the chopped onion and saut\u00e9 until translucent, about 4 minutes.",
    "Stir in the minced garlic and ginger, cooking until fragrant, 1\u20132 minutes.",
    "Add the diced eggplant and cook, stirring occasionally, until it starts to soften, about 5 minutes.",
    "Mix in the tomato paste and spice blend (cumin, coriander) and stir to coat the vegetables.",
    "Pour in the water or broth, bring to a simmer, and cover. Let the curry cook until the eggplant is tender, about 10 minutes.",
    "Stir in the tahini, chopped mint, and lemon juice, and season with salt and pepper to taste. Simmer for another 2 minutes to meld flavors.",
    "Serve hot, optionally garnished with extra mint leaves."
  ],
