  "ingredients": [
    {
      "name": "Chervil",
      "amount": "1 bunch",
      "notes": "Fresh and fragrant."
    },
    {
      "name": "Garlic",
      "amount": "2 cloves",
      "notes": "Mince for best flavor."
    },
    {
      "name": "Lemon",
      "amount": "1",
      "notes": "Juice for garnish."
    },
    {
      "name": "Toast",
      "amount": "4 slices",
      "notes": "Day-old bread works best."
    },
    {
      "name": "Olive Oil",
      "amount": "2 tbsp",
      "notes": "For toasting bread."
    },
    {
      "name": "Salt",
      "amount": "to taste",
      "notes": "For seasoning."
    },
    {
      "name": "Black Pepper",
      "amount": "to taste",
      "notes": "For seasoning."
    },
    {
      "name": "Water",
      "amount": "2 tbsp",
      "notes": "For rehydrating chervil."
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "Toast bread for 2-3 minutes, or until lightly browned.",
    "In a small bowl, combine minced garlic and 1 tbsp olive oil. ",
    "Brush garlic mixture onto toasted bread. ",
    "Rehydrate chervil by soaking it in 2 tbsp water for 5 minutes.",
    "Pat dry chervil with a paper towel and chop finely. ",
    "Sprinkle chopped chervil over garlic-infused bread. ",
    "Season with salt and black pepper to taste.",
    "Drizzle with lemon juice and serve immediately.",
    "Serve in a lacquerware bowl for a touch of elegance.",
    " Garnish with additional chervil if desired."
  ],
