  "ingredients": [
    {
      "name": "ground beef",
      "amount": "500g"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "finely chopped"
    },
    {
      "name": "potato",
      "amount": "2 large",
      "notes": "thinly sliced"
    },
    {
      "name": "carrot",
      "amount": "2 medium",
      "notes": "peeled and grated"
    },
    {
      "name": "celery",
      "amount": "2 stalks",
      "notes": "finely chopped"
    },
    {
      "name": "beef broth",
      "amount": "250ml"
    },
    {
      "name": "eggs",
      "amount": "2",
      "notes": "beaten"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "pepper",
      "amount": "1 tsp"
    },
    {
      "name": "parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "In a large pan over medium heat, sauté the onion, carrot, and celery in a little oil until softened.",
    "Add the minced beef and cook, breaking it up with a spoon, until browned.",
    "Stir in the beef broth and bring to a simmer.",
    "Transfer the mixture to a 9x13 inch baking dish.",
    "Arrange the sliced potatoes on top, overlapping slightly.",
    "Drizzle with eggs and sprinkle with salt, pepper, and parsley.",
    "Bake for 35 minutes or until the potatoes are golden brown and the filling is hot and bubbly.",
    "Serve hot, garnished with additional parsley if desired."
  ],
