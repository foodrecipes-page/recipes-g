{
  "title": "German Beef Bake",
  "description": "A light and flavorful post-workout dish featuring minced beef and a crispy potato crust. Perfect for a weeknight dinner.",
  "cuisine": "german",
  "diet": [
    "halal",
    "gluten-free"
  ],
