      "notes": "boneless and skinless"
    },
    {
      "name": "chicken stock cube",
      "amount": "2 cubes"
    },
    {
      "name": "basmati rice",
      "amount": "2 cups"
    },
    {
      "name": "almonds",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
