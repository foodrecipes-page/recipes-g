      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "pistachios",
      "amount": "1/2 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the slate-tile vessel over medium heat.",
    "Add the olive oil, chopped onion, and minced garlic, and cook until the onion is translucent.",
    "Add the sliced almonds and cook for 2 minutes, stirring frequently.",
    "Add the chicken breast and cook until browned on all sides.",
    "Add the chicken stock cube, salt, and black pepper, and stir to combine.",
    "Add the basmati rice and stir to combine with the chicken and spices.",
    "Add 4 cups of water to the vessel and bring to a boil.",
    "Reduce the heat to low, cover the vessel, and simmer for 20 minutes.",
    "Stir in the chopped pistachios and serve hot."
  ],
