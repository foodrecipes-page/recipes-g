      "amount": "1/4 cup (30g)",
      "notes": "toasted for crunch"
    },
    {
      "name": "Coconut Milk",
      "amount": "2 tablespoons (30g)",
      "notes": null
    },
    {
      "name": "Fish Sauce",
      "amount": "1 tablespoon (15g)",
      "notes": null
    },
    {
      "name": "Calamansi Juice",
      "amount": "1 tablespoon (15g)",
      "notes": null
    },
    {
      "name": "White Sugar",
      "amount": "1 tablespoon (12.5g)",
      "notes": null
    },
    {
