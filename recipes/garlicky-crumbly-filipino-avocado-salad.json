    },
    {
      "name": "Ground Black Pepper",
      "amount": "1/4 teaspoon",
      "notes": null
    },
    {
      "name": "Fresh Cilantro",
      "amount": "1 tablespoon, chopped (optional)",
      "notes": null
    }
