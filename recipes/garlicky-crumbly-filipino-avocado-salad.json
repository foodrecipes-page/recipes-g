{
  "title": "Garlicky Crumbly Filipino Avocado Salad",
  "description": "A fresh, garlicky avocado salad with a tangy vinaigrette and crisp toasted cornflake crumbs, perfect for a light snack or side.",
  "cuisine": "Filipino",
  "diet": [
    "vegetarian"
  ],
