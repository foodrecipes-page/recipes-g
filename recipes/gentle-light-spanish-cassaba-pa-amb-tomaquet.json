      "amount": "2 cups diced",
      "notes": "fresh"
    },
    {
      "name": "tomato",
      "amount": "1 cup diced",
      "notes": "fresh"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves minced"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "fresh basil",
      "amount": "1/4 cup chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees.",
    "In a large bowl, combine the diced cassaba melon and tomato.",
    "In a small bowl, whisk together the olive oil, garlic, lemon juice, salt, and pepper.",
    "Pour the dressing over the melon and tomato mixture, and toss to coat.",
    "Spread the mixture on a baking sheet, and bake for 20 minutes.",
    "Remove from the oven, and stir in the chopped fresh basil.",
    "Serve the mixture on toasted bread, and enjoy as pa amb tomaquet.",
    "Garnish with additional basil, if desired.",
    "Let it cool for a few minutes before serving."
  ],
