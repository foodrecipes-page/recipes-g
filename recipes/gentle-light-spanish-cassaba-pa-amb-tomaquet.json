{
  "title": "Gentle Light Spanish Cassaba Pa Amb Tomaquet",
  "description": "A floral and light Spanish dish featuring cassaba, perfect for a hangover cure, with a dairy-free friendly mother sauce base, served as pa amb tomaquet.",
  "cuisine": "Spanish",
  "diet": [
    "dairy-free",
    "vegetarian"
